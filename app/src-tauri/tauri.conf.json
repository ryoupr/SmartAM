{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SmartAM",
  "version": "0.1.4",
  "identifier": "com.smartam.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SmartAM",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3NTQ5RkY3REQ3REZFODMKUldTRC9uM2Q5NTlVRjBlazZTK01LRFQxanRhVXI0VUpaK29xbDFaZFNackJwZkVMK25kM1BqU04K",
      "endpoints": [
        "https://github.com/ryoupr/SmartAM/releases/latest/download/latest.json"
      ]
    }
  }
}
